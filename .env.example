# ============================================================
# Cylinder Distribution Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGO_URI=mongodb://localhost:27017/cylinder_platform
MONGO_URI_TEST=mongodb://localhost:27017/cylinder_platform_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=3600

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Inventory
LOW_STOCK_THRESHOLD=10

# Notifications (stubs — replace with real keys)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cylinderplatform.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

FCM_SERVER_KEY=

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Maps (extensible for Google Maps API)
GOOGLE_MAPS_API_KEY=

# Admin Seed
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@cylinderplatform.com
ADMIN_PASSWORD=Admin@123456
ADMIN_PHONE=+919999999999
